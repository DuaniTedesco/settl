# Copie este arquivo para .env e preencha os valores
# NUNCA envie o .env para o Git

# Obrigatório — gere uma chave forte:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-substitua-por-uma-chave-longa-e-aleatoria

# False em produção, True apenas em desenvolvimento local
DEBUG=False

# Domínio do Render (ex: settl.onrender.com) + localhost para dev
ALLOWED_HOSTS=localhost,127.0.0.1

# Preenchido automaticamente pelo Render se usar PostgreSQL
# Em dev local, deixe vazio para usar SQLite
# DATABASE_URL=postgresql://user:pass@host/dbname
